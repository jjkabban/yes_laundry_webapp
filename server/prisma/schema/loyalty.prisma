enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED // manual admin correction
}

model LoyaltyAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  pointsBalance Int @default(0) // current balance, denormalized for fast reads

  transactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyTransaction {
  id String @id @default(cuid())

  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id])

  type   LoyaltyTransactionType
  points Int // positive for earned, negative for redeemed

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  rewardRedemptionId String?
  rewardRedemption   RewardRedemption? @relation(fields: [rewardRedemptionId], references: [id])

  description String?

  createdAt DateTime @default(now())
}
