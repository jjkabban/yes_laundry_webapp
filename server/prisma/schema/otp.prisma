enum Purpose {
  SIGN_UP
  RESET_PASSWORD
}

model Otp {
  id          String   @id @default(uuid())
  phoneNumber String?
  email       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  codeHash    String   @unique
  purpose     Purpose?
  expiresAt   DateTime
  verified    Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
}
