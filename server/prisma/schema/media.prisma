enum MediaType {
  PICTURE
  FILE
  VIDEO
}

model Media {
  id           String         @id @default(uuid())
  url          String
  type         MediaType
  mimeType     String
  size         String
  userProfile  User?
  howItWorks   HowItWorks[]
  serviceCover Service? @relation("ServiceCoverImage")
  serviceMedia ServiceMedia[]
  createdAt    DateTime       @default(now())
}
